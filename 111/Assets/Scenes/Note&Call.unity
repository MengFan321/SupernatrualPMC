  updateSound: {fileID: 8300000, guid: b44cf31ccabbf724f88cd9b3391e2e78, type: 3}
  initialManualText: "\u4F4F\u6237\u6765\u7535\u540E\u8BF7\u8010\u5FC3\u503E\u542C\uFF0C\u627E\u5230\u987E\u5BA2\u771F\u6B63\u60F3\u89E3\u51B3\u7684\u95EE\u9898\u5E76\u7528\u94A2\u7B14\u6807\u8BB0\uFF0C\u6700\u597D\u6CE8\u610F\u90A3\u4E9B\u4E0D\u5BFB\u5E38\u7684\u53E5\u5B50\u3002"
  afterFirstCallText: "\u5982\u679C\u4F60\u89C9\u5F97\u592A\u4E3A\u96BE\uFF0C\u684C\u5B50\u4E0A\u7684\u9AB0\u5B50\u5E2E\u52A9\u8FC7\u4E0D\u5C11\u8D70\u6295\u65E0\u8DEF\u7684\u4EBA"
  afterFirstResidentText: "\u6700\u8FD1\u7559\u8A00\u7CFB\u7EDF\u51FA\u4E86\u95EE\u9898\uFF0C\u4E00\u6B21\u53EA\u80FD\u540C\u65F6\u663E\u793A\u4E09\u53E5\u8BDD"
  afterSecondResidentText: "\u6211\u53F8\u5F15\u8FDB\u4E86\u4E00\u6279\u5148\u8FDB\u7684\u8BBE\u5907\uFF0C\u6709\u6761\u4EF6\u7684\u5458\u5DE5\u53EF\u4EE5\u81EA\u884C\u8D2D\u4E70"
  afterLastResidentText: "\u623F\u95F4\u7684\u94A5\u5319\u4E22\u5931\u5F88\u4E45\u4E86\uFF0C\u6700\u540E\u4E00\u4E2A\u89C1\u5230\u5B83\u7684\u4EBA\u8BF4\u5B83\u53D8\u6210\u4E86\u4E00\u4E9B\u91D1\u8272\u7684\u788E\u7247\uFF0C\u843D\u8FDB\u4E00\u4E9B\u7269\u54C1\u91CC\u4E86\u3002"
